# VigilAfrica — Environment Variables

# Copy this file to .env and fill in the values.
# NEVER commit .env to the repository.

# ──────────────────────────────────────────────
# Required for v0.2+ (database)
# ──────────────────────────────────────────────

# PostgreSQL connection string
# Local dev example: postgres://vigilafrica:password@localhost:5432/vigilafrica
DATABASE_URL=

# ──────────────────────────────────────────────
# Required for v0.4+ (IP geolocation)
# ──────────────────────────────────────────────

# Absolute path to MaxMind GeoLite2-City .mmdb file
# Register free at https://www.maxmind.com/en/geolite2/signup
# Download GeoLite2-City.mmdb and place it somewhere safe (e.g. /data/GeoLite2-City.mmdb)
# Do NOT commit the .mmdb file to the repository.
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# ──────────────────────────────────────────────
# Optional — API server config
# ──────────────────────────────────────────────

# HTTP port for the Go API server (default: 8080)
API_PORT=8080

# Allowed CORS origin — set to your Vercel domain in production
# Local dev: use * or http://localhost:5173
CORS_ORIGIN=*

# Structured log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Optional — Ingestion config (v0.5+)
# ──────────────────────────────────────────────

# How often to poll NASA EONET in minutes (default: 60)
INGEST_INTERVAL_MINUTES=60

# API rate limit in requests per minute (default: 60)
RATE_LIMIT_RPM=60

# ──────────────────────────────────────────────
# Build-time injection (not a runtime env var)
# ──────────────────────────────────────────────

# Injected via: go build -ldflags "-X main.version=0.1.0" ./cmd/server/
# Do not set this at runtime — it is baked into the binary at build time.
# APP_VERSION=0.1.0

# ──────────────────────────────────────────────
# Frontend (Vite — prefix VITE_ for browser access)
# ──────────────────────────────────────────────

# API base URL for the React frontend
# Local dev: http://localhost:8080
# Production: https://api.vigilafrica.io
VITE_API_BASE_URL=http://localhost:8080
