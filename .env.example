# VigilAfrica — Environment Variables

# Copy this file to .env and fill in the values.
# NEVER commit .env to the repository.

# ──────────────────────────────────────────────
# Required for v0.2+ (database)
# ──────────────────────────────────────────────

# PostgreSQL connection string
# Local dev example: postgres://vigilafrica:password@localhost:5432/vigilafrica
DATABASE_URL=

# ──────────────────────────────────────────────
# Required for v0.4+ (IP geolocation)
# ──────────────────────────────────────────────

# Absolute path to MaxMind GeoLite2-City .mmdb file
# Register free at https://www.maxmind.com/en/geolite2/signup
# Download GeoLite2-City.mmdb and place it somewhere safe (e.g. /data/GeoLite2-City.mmdb)
# Do NOT commit the .mmdb file to the repository.
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb


# ──────────────────────────────────────────────
# Optional — API server config
# ──────────────────────────────────────────────

# HTTP port for the Go API server (default: 8080)
API_PORT=8080

# Allowed CORS origin — set to your frontend domain in production
# Local dev: use * or http://localhost:5173
# Production: https://vigilafrica.org or https://staging.vigilafrica.org
CORS_ORIGIN=*

# Structured log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Public API documentation exposure. Keep true for local/staging; set false
# for production if /docs and /openapi.yaml should not be public.
API_DOCS_ENABLED=true

# Comma-separated proxy CIDRs whose X-Forwarded-For/X-Real-IP headers may be
# trusted. Keep narrow and match the host/container network where Caddy reaches
# the API.
TRUSTED_PROXY_CIDRS=127.0.0.1/8,::1/128,172.16.0.0/12

# ──────────────────────────────────────────────
# Required for v0.5+ (ingestion alerting — ADR-011)
# ──────────────────────────────────────────────

# Deploy environment tag — appears in alert email subjects so staging pages
# can be told apart from production at a glance.
# Valid values: local | staging | production | demo
# Defaults to "unknown" if unset — that's intentional, so missing config is
# visible in the next alert rather than silently mislabelled.
# The staging/prod docker-compose files hardcode this; only override locally.
APP_ENV=local

# Resend API key — register free at https://resend.com
# Email alerts are disabled if this is not set
RESEND_API_KEY=

# Comma-separated recipient list for failure and staleness alerts
# Example: ops@example.com,maintainer@example.com
ALERTS_TO=

# Legacy single-recipient fallback; prefer ALERTS_TO for new deployments
ALERT_EMAIL_TO=

# Verified sender address in your Resend account (must match a verified domain)
# Default: alerts@vigilafrica.org — override with your verified Resend sender
ALERT_FROM_EMAIL=

# Hours without a successful ingestion before a staleness alert fires (default: 2)
ALERT_STALENESS_THRESHOLD_HOURS=2

# How often the staleness watchdog checks ingestion health, in minutes (default: 15)
ALERT_STALENESS_CHECK_INTERVAL_MIN=15

# ──────────────────────────────────────────────
# Optional — Daily flood digest (feature-daily-flood-digest)
# ──────────────────────────────────────────────

# Comma-separated recipients for the daily flood digest email.
# Reuses RESEND_API_KEY above. Leave empty to disable the digest entirely
# (the scheduler logs that it is disabled and sends nothing — the default for
# local dev and CI). The GET /v1/digest/today.json endpoint works regardless.
# Example: focal-point@redcross.example,ops@example.com
DIGEST_TO=

# Verified sender for the digest (defaults to "VigilAfrica Digest <digest@vigilafrica.org>").
DIGEST_FROM=

# UTC hour-of-day (0–23) to send the digest (default: 6). Note: "today" is the
# UTC calendar day; Nigeria is UTC+1.
DIGEST_SCHEDULE_HOUR=6

# ──────────────────────────────────────────────
# Optional — Ingestion config (v0.5+)
# ──────────────────────────────────────────────

# How often to poll NASA EONET in minutes (default: 60)
INGEST_INTERVAL_MIN=60

# API rate limit in requests per minute, per client IP (default: 60)
RATE_LIMIT_RPM=60

# Lighter public limiter for /health, /ready, /docs, and /openapi.yaml
# (requests per minute, per client IP; default: 300)
GLOBAL_RATE_LIMIT_RPM=300

# Bound in-memory per-IP rate-limit buckets (default: 10000)
RATE_LIMIT_MAX_BUCKETS=10000

# Evict idle rate-limit buckets after this many seconds (default: 900)
RATE_LIMIT_BUCKET_TTL_SECONDS=900

# Response cache TTL for GET /v1/events in seconds (default: 300)
CACHE_TTL_SECONDS=300

# Bound in-memory response cache entries (default: 1000)
CACHE_MAX_ENTRIES=1000

# Reject cached GET requests with query strings larger than this many bytes
# (default: 1024)
CACHE_MAX_QUERY_BYTES=1024

# ──────────────────────────────────────────────
# Build-time injection (not a runtime env var)
# ──────────────────────────────────────────────

# Injected via: go build -ldflags "-X main.version=0.1.0" ./cmd/server/
# Do not set this at runtime — it is baked into the binary at build time.
# APP_VERSION=0.1.0

# ──────────────────────────────────────────────
# Required for v1.3+ (self-hosted Umami analytics — chore-analytics-and-feedback)
# ──────────────────────────────────────────────

# Password for the `umami` Postgres role (separate from the main vigilafrica
# DB role). MUST be set in any staging / production .env.
# Generate with: openssl rand -base64 24
# Local dev: docker-compose.yml falls back to a known-weak default since the
# port only binds to 127.0.0.1. Override here if you want.
UMAMI_DB_PASSWORD=

# Umami session-signing secret. MUST be set in any staging / production .env.
# Generate with: openssl rand -base64 32
# Local dev: docker-compose.yml falls back to a known-weak default.
UMAMI_APP_SECRET=

# ──────────────────────────────────────────────
# Frontend (Vite — prefix VITE_ for browser access)
# ──────────────────────────────────────────────

# API base URL for the React frontend
# Local dev: http://localhost:8080
# Production: https://api.vigilafrica.org
# Staging: https://api.staging.vigilafrica.org
VITE_API_BASE_URL=http://localhost:8080

# Self-hosted Umami analytics URL — origin only, no trailing slash.
# The tracker script is loaded from `${VITE_ANALYTICS_URL}/script.js`.
# Local dev: leave blank (tracker will fail to load — that is fine for dev).
# Production: https://analytics.vigilafrica.org
# Staging: https://analytics.staging.vigilafrica.org
# vite.config.ts asserts this is set when VITE_ENV ∈ {staging, production}
# (extends the F3 build-time assertion shipped in v1.2).
VITE_ANALYTICS_URL=

# Umami website ID — public identifier (visible in HTML), not a secret.
# Created in the Umami dashboard at `${VITE_ANALYTICS_URL}/settings/websites`
# the first time a website is registered. One per environment is fine.
# Local dev: leave blank.
# Asserted alongside VITE_ANALYTICS_URL in vite.config.ts.
VITE_ANALYTICS_WEBSITE_ID=

# Show diagnostic detail (attempted API URL + raw error message) on the
# dashboard connection-error state. Set to "true" for local dev and the
# Vercel staging project; leave unset/empty for the production project so
# end users see only the generic "Failed to connect" copy (per §10.4).
VITE_SHOW_ERROR_DETAIL=true
